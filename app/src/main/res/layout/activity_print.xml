<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PrintActivity">

    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_diary_pattern"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_rounded_button"
        android:fontFamily="@font/memoment_kkukkukk"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="뒤로가기"
        android:textColor="@color/text_main"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/memoment_kkukkukk"
        android:text="프린트"
        android:textColor="#5D4037"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_back" />

    <TextView
        android:id="@+id/btn_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_rounded_button"
        android:fontFamily="@font/memoment_kkukkukk"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="메인"
        android:textColor="#5D4037"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_back" />

    <View
        android:id="@+id/view_underline"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#D2B48C"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back" />

    <LinearLayout
        android:id="@+id/ll_selected_sticker"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_rounded_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_print_trigger"
        app:layout_constraintTop_toBottomOf="@id/view_underline">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
            <ImageView android:id="@+id/iv_print_1" android:layout_width="0dp" android:layout_height="130dp" android:layout_margin="6dp" android:layout_weight="1" android:scaleType="fitCenter" />
            <ImageView android:id="@+id/iv_print_2" android:layout_width="0dp" android:layout_height="130dp" android:layout_margin="6dp" android:layout_weight="1" android:scaleType="fitCenter" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
            <ImageView android:id="@+id/iv_print_3" android:layout_width="0dp" android:layout_height="130dp" android:layout_margin="6dp" android:layout_weight="1" android:scaleType="fitCenter" />
            <ImageView android:id="@+id/iv_print_4" android:layout_width="0dp" android:layout_height="130dp" android:layout_margin="6dp" android:layout_weight="1" android:scaleType="fitCenter" />
        </LinearLayout>

        <ImageView android:id="@+id/iv_print_5" android:layout_width="130dp" android:layout_height="130dp" android:layout_margin="6dp" android:scaleType="fitCenter" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_print_trigger"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_rounded_card"
        android:fontFamily="@font/memoment_kkukkukk"
        android:text="프린트 하기"
        android:textColor="@color/text_header"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>