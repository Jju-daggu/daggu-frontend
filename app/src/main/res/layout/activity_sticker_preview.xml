<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StickerPreviewActivity">

    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_diary_pattern"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_rounded_button"
        android:fontFamily="@font/memoment_kkukkukk"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="뒤로가기"
        android:textColor="@color/text_main"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView android:id="@+id/tv_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/memoment_kkukkukk" android:text="미리보기" android:textColor="#5D4037" android:textSize="22sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="@id/btn_back" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="@id/btn_back" />
    <TextView android:id="@+id/btn_main" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="16dp" android:background="@drawable/bg_rounded_button" android:fontFamily="@font/memoment_kkukkukk" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="메인" android:textColor="#5D4037" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="@id/btn_back" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/btn_back" />
    <View android:id="@+id/view_underline_top" android:layout_width="0dp" android:background="#D2B48C" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/btn_back" android:layout_height="1dp" android:layout_marginTop="12dp" />

    <LinearLayout
        android:id="@+id/ll_preview"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_rounded_card"
        android:gravity="center"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/view_underline_top">
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="2"
            android:rowCount="3">

            <ImageView android:id="@+id/iv_sticker_1" android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="8dp" android:scaleType="fitCenter" android:src="@drawable/s5" />
            <ImageView android:id="@+id/iv_sticker_2" android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="8dp" android:scaleType="fitCenter" android:src="@drawable/s6" />
            <ImageView android:id="@+id/iv_sticker_3" android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="8dp" android:scaleType="fitCenter" android:src="@drawable/s7" />
            <ImageView android:id="@+id/iv_sticker_4" android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="8dp" android:scaleType="fitCenter" android:src="@drawable/s8" />
            <ImageView android:id="@+id/iv_sticker_5" android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="8dp" android:scaleType="fitCenter" android:src="@drawable/s9" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" />
        </GridLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_keyword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_rounded_card"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingVertical="16dp"
        app:layout_constraintEnd_toEndOf="@id/ll_preview"
        app:layout_constraintStart_toStartOf="@id/ll_preview"
        app:layout_constraintTop_toBottomOf="@id/ll_preview">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/memoment_kkukkukk"
            android:text="스티커 스타일"
            android:textColor="#8D6E63"
            android:textSize="20sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:id="@+id/tv_style_vintage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/memoment_kkukkukk"
                    android:text="빈티지"
                    android:textColor="#A1887F"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="3dp"
                    android:clickable="true"
                    android:focusable="true"/>
                <View
                    android:layout_width="1.5dp"
                    android:layout_height="18dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="#D2B48C" />
                <TextView
                    android:id="@+id/tv_style_cute"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/memoment_kkukkukk"
                    android:text="손그림"
                    android:textColor="#F06292"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="3dp"
                    android:clickable="true"
                    android:focusable="true"/>
                <View
                    android:layout_width="1.5dp"
                    android:layout_height="18dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="#D2B48C" />
                <TextView
                    android:id="@+id/tv_style_polaroid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/memoment_kkukkukk"
                    android:text="폴라로이드"
                    android:textColor="#4FC3F7"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="3dp"
                    android:clickable="true"
                    android:focusable="true"/>
                <View
                    android:layout_width="1.5dp"
                    android:layout_height="18dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="#D2B48C" />
                <TextView
                    android:id="@+id/tv_style_pixel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/memoment_kkukkukk"
                    android:text="픽셀"
                    android:textColor="#BA68C8"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="3dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/ll_keyword"
        app:layout_constraintEnd_toEndOf="@id/ll_preview"
        app:layout_constraintStart_toStartOf="@id/ll_preview">

        <LinearLayout
            android:id="@+id/btn_store"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="70dp" android:layout_height="70dp" android:scaleType="fitCenter" android:src="@drawable/ic_archive" />
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_button"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/memoment_kkukkukk" android:text="보관" android:textColor="#5D4037" android:textSize="15sp" android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_place"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:id="@+id/iv_icon_place" android:layout_width="70dp" android:layout_height="70dp" android:scaleType="fitCenter" android:src="@drawable/ic_place" />
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_button"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/memoment_kkukkukk" android:text="배치" android:textColor="#5D4037" android:textSize="15sp" android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_print"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="70dp" android:layout_height="70dp" android:scaleType="fitCenter" android:src="@drawable/ic_print" />
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_button"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/memoment_kkukkukk" android:text="프린트" android:textColor="#5D4037" android:textSize="15sp" android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>