<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_paper"
    tools:context=".DashboardActivity">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="다꾸메이커"
        android:textColor="@color/black"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/ll_recent_stickers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <LinearLayout android:layout_width="70dp" android:layout_height="120dp" android:layout_margin="8dp" android:background="@drawable/bg_rounded_card" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18" android:textSize="24sp" android:textStyle="bold" />
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_marginTop="8dp" android:background="@drawable/bg_circle_red" />
        </LinearLayout>
        <LinearLayout android:layout_width="70dp" android:layout_height="120dp" android:layout_margin="8dp" android:background="@drawable/bg_rounded_card" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="17" android:textSize="24sp" android:textStyle="bold" />
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_marginTop="8dp" android:background="@drawable/bg_circle_orange" />
        </LinearLayout>
        <LinearLayout android:layout_width="70dp" android:layout_height="120dp" android:layout_margin="8dp" android:background="@drawable/bg_rounded_card" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="16" android:textSize="24sp" android:textStyle="bold" />
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_marginTop="8dp" android:background="@drawable/bg_circle_red" />
        </LinearLayout>
        <LinearLayout android:layout_width="70dp" android:layout_height="120dp" android:layout_margin="8dp" android:background="@drawable/bg_rounded_card" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15" android:textSize="24sp" android:textStyle="bold" />
            <View android:layout_width="40dp" android:layout_height="40dp" android:layout_marginTop="8dp" android:background="@drawable/bg_circle_blue" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btn_upload"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_rounded_card"
        android:text="사진 업로드"
        android:textColor="@color/pastel_red"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_recent_stickers" />

    <Button
        android:id="@+id/btn_vault"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_rounded_card"
        android:text="스티커 보관함"
        android:textColor="@color/pastel_orange"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_upload" />

</androidx.constraintlayout.widget.ConstraintLayout>