<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/paper"
    tools:context=".DashboardActivity">

    <com.example.daggumaker.StrokeTextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:fontFamily="@font/diary_font"
        android:text="다꾸메이커"
        android:textColor="#FFFFFF"
        android:textSize="70sp"
        app:text_stroke="true"
        app:text_stroke_color="#000000"
        app:text_stroke_width="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_view_calendar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="28dp"
        android:fontFamily="@font/diary_font"
        android:text="전체보기 〉"
        android:textColor="#707070"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <LinearLayout
        android:id="@+id/ll_recent_stickers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_view_calendar">

        <View
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_rounded_card" />
        <View
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_rounded_card" />
        <View
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_rounded_card" />
        <View
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_rounded_card" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_upload"
        android:layout_width="248dp"
        android:layout_height="92dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_rounded_card"
        android:elevation="6dp"
        android:fontFamily="@font/diary_font"
        android:text="스티커 업로드"
        android:textColor="#FF9E9E"
        android:textSize="36sp"
        app:layout_constraintTop_toBottomOf="@id/ll_recent_stickers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_vault"
        android:layout_width="237dp"
        android:layout_height="196dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_rounded_card"
        android:elevation="6dp"
        android:fontFamily="@font/diary_font"
        android:gravity="center"
        android:lineSpacingExtra="5dp"
        android:text="스티커\n보관함"
        android:textColor="#FFC47E"
        android:textSize="50sp"
        app:layout_constraintTop_toBottomOf="@id/btn_upload"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>