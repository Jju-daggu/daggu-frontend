<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/paper"
    tools:context=".VaultActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_rounded_button"
            android:fontFamily="@font/diary_font"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="뒤로가기"
            android:textColor="#555555"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:fontFamily="@font/diary_font"
            android:gravity="center"
            android:text="스티커 보관함"
            android:textColor="#7A5C46"
            android:textSize="26sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_main"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/btn_main"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_rounded_button"
            android:fontFamily="@font/diary_font"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="메인"
            android:textColor="#555555"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#E0D8CC"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_vault_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="30dp"
        app:cardBackgroundColor="#FFFCF8"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_top_bar">

        <ScrollView
            android:id="@+id/sv_vault"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:id="@+id/layout_new_stickers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                        <ImageView android:id="@+id/iv_new_1" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" />
                        <ImageView android:id="@+id/iv_new_2" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                        <ImageView android:id="@+id/iv_new_3" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" />
                        <ImageView android:id="@+id/iv_new_4" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                        <ImageView android:id="@+id/iv_new_5" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" />
                        <View android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0D8CC" android:layout_marginVertical="10dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                    <ImageView android:id="@+id/iv_vault_1" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" android:src="@drawable/s4" />
                    <ImageView android:id="@+id/iv_vault_2" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" android:src="@drawable/s3" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                    <ImageView android:id="@+id/iv_vault_3" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" android:src="@drawable/s2" />
                    <ImageView android:id="@+id/iv_vault_4" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" android:src="@drawable/s1" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                    <ImageView android:id="@+id/iv_vault_5" android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" android:scaleType="fitCenter" android:src="@drawable/s0" />
                    <View android:layout_width="0dp" android:layout_height="180dp" android:layout_margin="8dp" android:layout_weight="1" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>